menu "AHT20 I2C Configuration"

    config I2C_MASTER_SDA
        int "AHT20 I2C SDA GPIO"
        default 8
        range 0 48
        help
            GPIO used for the AHT20 I2C SDA line.

    config I2C_MASTER_SCL
        int "AHT20 I2C SCL GPIO"
        default 9
        range 0 48
        help
            GPIO used for the AHT20 I2C SCL line.

endmenu